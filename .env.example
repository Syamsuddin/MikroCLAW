# Salin ke .env lalu isi sesuai router Anda:  cp .env.example .env
# .env TIDAK di-commit (lihat .gitignore).

# Alamat/host RouterOS (wajib)
MIKROTIK_HOST=192.168.88.1

# Kredensial. Disarankan buat user least-privilege khusus, bukan 'admin' penuh.
MIKROTIK_USER=mikroclaw
MIKROTIK_PASSWORD=ganti-saya

# Transport REST. TLS aktif -> port default 443; non-TLS -> 80.
MIKROTIK_USE_TLS=true
MIKROTIK_PORT=443

# Verifikasi sertifikat TLS. RouterOS umumnya pakai self-signed -> false.
# Set true kalau Anda sudah memasang sertifikat tepercaya.
MIKROTIK_VERIFY_TLS=false

# Timeout request (detik)
MIKROTIK_TIMEOUT=10

# GERBANG KEAMANAN: false = read-only (default). Set true untuk mengizinkan
# operasi yang MENGUBAH konfigurasi (enable/disable interface, tambah firewall, dll).
MIKROCLAW_ALLOW_WRITE=false
